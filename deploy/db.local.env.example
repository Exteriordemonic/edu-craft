# Local (DDEV) database — copy to deploy/db.local.env and adjust if needed.
# Matches web/wp-config-ddev.php (IS_DDEV_PROJECT). Use from inside DDEV (e.g. ddev ssh); on the host use `ddev mysql` or 127.0.0.1 + port from `ddev describe`.
DB_NAME=db
DB_USER=db
DB_PASSWORD=db
DB_HOST=ddev-edu-craft-db
