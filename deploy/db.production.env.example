# Production (MyDevil) database — copy to deploy/db.production.env and fill in real values.
# Never commit deploy/db.production.env.
#
# DB_HOST is often localhost on shared hosting; use the value from the hosting panel if different.

DB_NAME=your_production_database_name
DB_USER=your_production_database_user
DB_PASSWORD=your_production_database_password
DB_HOST=localhost
